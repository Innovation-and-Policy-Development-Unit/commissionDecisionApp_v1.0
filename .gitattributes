# Normalize line endings: store as LF in the repo, check out as-is on each OS
* text=auto

# Force LF for files that must stay LF (scripts, Docker, configs)
*.sh        text eol=lf
Dockerfile  text eol=lf
*.py        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.env       text eol=lf
*.env.*     text eol=lf

# Binary files — no line-ending conversion
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pdf  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.eot  binary
