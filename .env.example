# ── SCDMS Production Environment Variables ──────────────────────────────
# Copy this file to .env and fill in all values.

# Django
DJANGO_SECRET_KEY=<generate-a-long-random-secret-key>
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=scdms.psc.gov.vu,localhost

# Database
POSTGRES_DB=commission_decision
POSTGRES_USER=scdms
POSTGRES_PASSWORD=<strong-db-password>
POSTGRES_HOST=db
POSTGRES_PORT=5432

# CORS / SPA (password-reset links in email use FRONTEND_URL when Origin is absent)
CORS_ALLOWED_ORIGINS=https://scdms.psc.gov.vu
FRONTEND_URL=https://scdms.psc.gov.vu

# Security
ALLOW_OPEN_REGISTRATION=false
TWO_FACTOR_REQUIRED=false
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true
SECURE_SSL_REDIRECT=true
SECURE_HSTS_SECONDS=31536000

# JWT
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=7

# Axes (brute-force protection)
AXES_FAILURE_LIMIT=5
AXES_COOLOFF_HOURS=1

# Email (SMTP)
EMAIL_BACKEND=tracker.email_backend.DynamicEmailBackend
DEFAULT_FROM_EMAIL=PSC Tracker Dev <dev@localhost>

# ── Development (Mailpit via docker compose) ─────────────────────────────────
# Web inbox: http://localhost:8025   SMTP: localhost:1025 (host) or mailpit:1025 (in Docker)
# Leave SMTP_HOST unset if you configure Gmail only in Admin → System Config.
# SMTP_HOST=mailpit
# SMTP_PORT=1025
# SMTP_TLS=false
# SMTP_SSL=false

# ── Gmail (App Password required — https://myaccount.google.com/apppasswords) ─
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_TLS=true
# SMTP_SSL=false
# SMTP_USER=your.account@gmail.com
# SMTP_PASSWORD=your-16-char-app-password

# ── Production (uncomment and remove dev Mailpit values above) ───────────────
# SMTP_HOST=<smtp-host>
# SMTP_PORT=587
# SMTP_USER=<smtp-user>
# SMTP_PASSWORD=<smtp-password>
# SMTP_TLS=true

# Redis / Celery (password required — must match docker-compose redis --requirepass)
REDIS_PASSWORD=<strong-redis-password>
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/0

# Monitoring
SENTRY_DSN=<your-sentry-dsn>
SENTRY_ENVIRONMENT=production

# Anthropic Claude (all AI features — see docs/ai-claude.md)
ANTHROPIC_API_KEY=<your-anthropic-api-key>
CLAUDE_MODEL_HAIKU=claude-haiku-4-5-20251001
CLAUDE_MODEL_SONNET=claude-sonnet-4-6

# web
WEB_PORT=443

# ── Render.com (see docs/deployment-render.md + render.yaml) ─────────────────
# DATABASE_URL=<from Render PostgreSQL>
# CELERY_BROKER_URL=<from Render Key Value Redis>
# RENDER=true
# CDP_BASE_URL=https://scdms-api.onrender.com
# VITE_API_BASE_URL=https://scdms-api.onrender.com/api   # scdms-web static site only

# ── Production TLS (docker-compose.prod.yml + docs/deployment-tls.md) ─────────
# DOMAIN=scdms.psc.gov.vu
# CERTBOT_EMAIL=admin@psc.gov.vu
